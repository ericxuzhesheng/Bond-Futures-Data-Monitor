__pycache__/
*.py[cod]
.pytest_cache/
.pytest_tmp/
.venv/
.env
# The production SQLite database is version-controlled for reliable cross-day
# history (see .github/workflows/daily-report.yml). Ignore everything else under
# data/ (transient files) but keep the canonical database tracked.
data/*
!data/bond_futures_monitor.db
reports_output/
logs/
.claude/settings.local.json
.claude/scheduled_tasks.lock
